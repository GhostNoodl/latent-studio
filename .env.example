# ─────────────────────────────────────────────────────────────────────────────
# Latent configuration. Copy this file to `.env` and adjust as needed.
# Every value here has a sensible default — an empty/absent .env works out of the
# box (Latent manages its own ComfyUI + keeps everything under ./data).
# ─────────────────────────────────────────────────────────────────────────────

# ComfyUI REST + WebSocket origin. Latent's managed ComfyUI listens here by default.
COMFYUI_URL=http://127.0.0.1:8188

# Backend listen config. HOST 0.0.0.0 makes it reachable from phones / other LAN
# devices (set ACCESS_TOKEN below if you expose it beyond localhost).
PORT=4000
HOST=0.0.0.0

# Where the app stores its SQLite DB, copied outputs, managed ComfyUI, and — by
# default — downloaded models and the tag CSV. Relative to the repo root.
DATA_DIR=./data

# Optional shared access token for LAN exposure. Leave blank to disable auth.
ACCESS_TOKEN=

# Stop Latent + its ComfyUI when the last browser tab closes (the launcher sets 1).
# AUTO_SHUTDOWN=1

# ── Optional overrides (defaults are self-contained under DATA_DIR) ────────────

# Model library root. Defaults to <DATA_DIR>/models. Point this at an existing,
# shared model folder if you already have one (e.g. a big external drive).
# SM_MODELS_DIR=D:\Models

# Tag-autocomplete CSV (danbooru/e621). Defaults to <DATA_DIR>/tags/danbooru_e621_merged.csv.
# Autocomplete simply stays off if the file is absent.
# TAGS_CSV=

# Wildcards directory (__name__ expansion). Defaults to <DATA_DIR>/wildcards.
# WILDCARDS_DIR=

# Your Civitai API key — needed to download NSFW/gated checkpoints from Civitai.
# You can also set this later in the app (Settings → Civitai). Get one at
# https://civitai.com/user/account
# CIVITAI_API_KEY=

# ── Advanced: drive an EXISTING ComfyUI instead of Latent's managed one ────────
# Leave these unset to use the managed portable ComfyUI (recommended). Set them
# only if you run ComfyUI via Stability Matrix and want Latent to launch it.
# STABILITY_MATRIX_DIR=C:\StabilityMatrix
# COMFYUI_DIR=C:\StabilityMatrix\Packages\ComfyUI

# Auto-update: on prod launch, the launcher fast-forwards a clean checkout to the
# latest from GitHub (never touches local changes / feature branches). Set to 0 to disable.
AUTO_UPDATE=1
